name = "wr3-edge"
main = "worker.ts"
compatibility_date = "2026-05-12"

[vars]
WR3_CORE_API_BASE = "https://api.wr3.example"

[[d1_databases]]
binding = "WR3_EDGE_DB"
database_name = "wr3-edge-metadata"
database_id = "REPLACE_WITH_D1_DATABASE_ID"

[[r2_buckets]]
binding = "WR3_ARTIFACTS"
bucket_name = "wr3-prod-artifacts"

[[r2_buckets]]
binding = "WR3_BACKUPS"
bucket_name = "wr3-prod-backups"
