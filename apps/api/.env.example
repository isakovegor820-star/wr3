# wr3 API configuration template. Copy to apps/api/.env and fill in.
# .env is gitignored — never commit real secrets. No inline comments after a
# value (the dotenv parser captures them); keep comments on their own lines.

# ─── mode ───────────────────────────────────────────────────────────────
# development (default) honours dev conveniences (X-WR3-Reviewer: true, the
# Telegram emulator header, anonymous local dashboard). production disables them.
WR3_ENVIRONMENT=development

# ─── autonomous scout ───────────────────────────────────────────────────
# Turn the 24/7 autopilot on. It pulls Immunefi scope + DeFiLlama and analyses
# targets. Run it supervised: bash scripts/run_autopilot_supervised.sh
WR3_SCOUT_AUTOPILOT_ENABLED=false

# ─── persistence ────────────────────────────────────────────────────────
# Postgres makes audits durable across restarts AND activates source-at-rest
# encryption (the in-memory store does neither). Omit for an ephemeral local run.
# WR3_DATABASE_URL=postgresql:///wr3_local

# ─── triage model ───────────────────────────────────────────────────────
# disabled = deterministic local triage (free, no network). For LLM triage set
# navy/openrouter + a key; cost is capped by WR3_LLM_MAX_CALLS_PER_DAY.
WR3_LLM_PROVIDER=disabled
# WR3_NAVY_API_KEY=
# WR3_LLM_MODEL=claude-opus-4-8
# WR3_LLM_MAX_CALLS_PER_DAY=500

# ─── at-rest encryption + reviewer access ───────────────────────────────
# Fernet key (python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())").
# Required to encrypt contract source in Postgres and to store private artifacts.
# WR3_ARTIFACT_ENCRYPTION_KEY=
# In production the dev "true" header is disabled; set a token and send it as
# the X-WR3-Reviewer header for dashboard/disclosure access.
# WR3_REVIEWER_TOKEN=

# ─── live fork-PoC ──────────────────────────────────────────────────────
# Confirm exploits against LIVE deployed contracts on a fork. Set an archive RPC
# AND add its host to the allowlist below (the fork sandbox only reaches allowed
# hosts). Without this, PoC runs source-only.
# WR3_POC_FORK_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
WR3_SANDBOX_ALLOWED_RPC_HOSTS=["127.0.0.1","localhost"]
# WR3_POC_FORK_BLOCK=

# ─── Telegram owner alerts (optional) ───────────────────────────────────
# WR3_TELEGRAM_BOT_TOKEN=
# WR3_TELEGRAM_REVIEWER_USER_IDS=["YOUR_TELEGRAM_USER_ID"]
# WR3_TELEGRAM_WEBHOOK_SECRET=
