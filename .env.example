# API
WR3_ENVIRONMENT=development
WR3_CORS_ORIGINS='["http://127.0.0.1:3000","http://127.0.0.1:3001"]'
# Native localhost default after `npm run setup:native`.
# Leave empty only when you explicitly want in-memory MVP storage.
WR3_DATABASE_URL=postgresql:///wr3_local
WR3_FREE_ONLY_MODE=true
WR3_OBJECT_STORAGE_MODE=local
WR3_BACKUP_DIR=artifacts/backups
WR3_BACKUP_TARGET=local
WR3_BACKUP_R2_URI=
WR3_BACKUP_ENCRYPTION_PASSPHRASE=
WR3_SENTRY_DSN=
WR3_TELEGRAM_ALERT_CHAT_ID=
WR3_USDC_RECEIVE_ADDRESS=
WR3_REQUEST_FINANCE_API_KEY=
WR3_REQUEST_FINANCE_INVOICE_BASE_URL=
WR3_POLAR_API_KEY=
WR3_POLAR_CHECKOUT_BASE_URL=
WR3_LEMON_SQUEEZY_API_KEY=
WR3_LEMON_SQUEEZY_CHECKOUT_BASE_URL=
WR3_TON_CONNECT_MANIFEST_URL=
WR3_WEB_BASE_URL=http://127.0.0.1:3001
WR3_TELEGRAM_WEBHOOK_SECRET=
WR3_TELEGRAM_BOT_TOKEN=
WR3_TELEGRAM_REVIEWER_USER_IDS=[]
WR3_TELEGRAM_MINI_APP_URL=
WR3_TELEGRAM_WEBHOOK_URL=
WR3_TELEGRAM_API_CHECK_URL=
WR3_TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
WR3_SIWE_SIGNATURE_VERIFICATION_ENABLED=false
WR3_EMAIL_DELIVERY_ENABLED=false
WR3_EMAIL_MAGIC_LINK_BASE_URL=
WR3_TASK_BACKEND=local
WR3_CELERY_BROKER_URL=redis://127.0.0.1:6379/0
WR3_CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
WR3_ARTIFACT_DIR=artifacts/local
WR3_AUDIT_TOOLS_BIN_DIR=artifacts/audit-tools-venv/bin
# Fernet key for sensitive artifact encryption. Generate in secure env, do not commit.
WR3_ARTIFACT_ENCRYPTION_KEY=
WR3_POC_MAX_ATTEMPTS=5
WR3_LLM_PROVIDER=disabled
WR3_LLM_MODEL=local-deterministic-triage
WR3_LLM_ZDR_REQUIRED=true
WR3_LLM_TIMEOUT_SECONDS=25
WR3_OPENROUTER_API_KEY=
# NavyAI local triage example:
# WR3_LLM_PROVIDER=navy
# WR3_LLM_MODEL=gpt-5.5
# WR3_NAVY_API_KEY=
# WR3_NAVY_BASE_URL=https://api.navy/v1
WR3_SOLODIT_API_BASE_URL=
WR3_SOLODIT_API_KEY=
WR3_DEFILLAMA_HACKS_URL=https://api.llama.fi/hacks
WR3_RSSHUB_BASE_URL=
WR3_HELIUS_API_KEY=
WR3_HELIUS_RPC_URL=
WR3_FORTA_API_KEY=
WR3_TENDERLY_API_KEY=
WR3_BLOCKSEC_API_KEY=
WR3_RESEND_API_KEY=
WR3_SANDBOX_ALLOWED_RPC_HOSTS='["127.0.0.1","localhost"]'
WR3_SANDBOX_DEFAULT_TIMEOUT_SECONDS=120
WR3_WEBHOOK_DELIVERY_ENABLED=false
WR3_WEBHOOK_TIMEOUT_SECONDS=5
WR3_WEBHOOK_SIGNING_SECRET=
WR3_SAFE_HARBOR_REGISTRY_PATH=
WR3_SAFE_HARBOR_REGISTRY_JSON=

# Web
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Future integrations
# Explorer source pull uses Etherscan API V2 first. One free
# WR3_ETHERSCAN_API_KEY is enough for Ethereum/Base/BSC/Arbitrum verified source
# via chainid. Legacy explorer-specific keys below are optional fallbacks.
WR3_ETHERSCAN_API_KEY=
WR3_ETHERSCAN_V2_BASE_URL=https://api.etherscan.io/v2/api
WR3_ETHERSCAN_V2_ENABLED=true
WR3_BASESCAN_API_KEY=
WR3_BSCSCAN_API_KEY=
WR3_ARBISCAN_API_KEY=
WR3_EXPLORER_TIMEOUT_SECONDS=8
WR3_EXPLORER_MAX_RETRIES=2
WR3_EXPLORER_RETRY_BACKOFF_SECONDS=0
WR3_PUBLIC_RPC_FALLBACK_ENABLED=true
WR3_ETHEREUM_RPC_URL=
WR3_BASE_RPC_URL=
WR3_BSC_RPC_URL=
WR3_ARBITRUM_RPC_URL=
WR3_SOLANA_RPC_URL=
OPENROUTER_API_KEY=
DOPPLER_TOKEN=
