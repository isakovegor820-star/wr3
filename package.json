{
  "name": "wr3-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "packages/audit-engine",
    "packages/scoring",
    "packages/shared",
    "packages/types"
  ],
  "scripts": {
    "build:packages": "npm --workspace @wr3/types run build && npm --workspace @wr3/scoring run build && npm --workspace @wr3/audit-engine run build && npm --workspace @wr3/shared run build",
    "build": "npm --workspace @wr3/types run build && npm --workspace @wr3/scoring run build && npm --workspace @wr3/audit-engine run build && npm --workspace @wr3/shared run build && npm --workspace @wr3/web run build",
    "benchmark:mvp": "apps/api/.venv/bin/python scripts/benchmark_runner.py",
    "benchmark:local": "apps/api/.venv/bin/python scripts/benchmark_local.py",
    "benchmark:curate": "python3 scripts/curate_benchmark_subset.py",
    "benchmark:curated-run": "apps/api/.venv/bin/python scripts/benchmark_curated_run.py",
    "benchmark:sync-external": "bash scripts/sync_benchmark_datasets.sh",
    "benchmark:inventory-external": "python3 scripts/external_benchmark_inventory.py",
    "rag:build-local": "python3 scripts/build_local_rag_corpus.py",
    "poc:local": "apps/api/.venv/bin/python scripts/poc_local.py",
    "fuzzing:local": "apps/api/.venv/bin/python scripts/fuzzing_local.py",
    "tools:install:local": "bash scripts/install_local_audit_tools.sh",
    "telegram:menu:setup": "apps/api/.venv/bin/python scripts/telegram_set_menu_button.py",
    "telegram:webhook:setup": "apps/api/.venv/bin/python scripts/telegram_set_webhook.py",
    "telegram:publish": "bash scripts/telegram_publish_current.sh",
    "calibration:scoring": "apps/api/.venv/bin/python scripts/scoring_calibration.py",
    "free-tier:readiness": "apps/api/.venv/bin/python scripts/free_tier_readiness.py",
    "local:readiness": "python3 scripts/local_readiness.py",
    "production:readiness": "python3 scripts/production_readiness.py",
    "secrets:readiness": "python3 scripts/secret_manager_readiness.py",
    "staging:preflight": "python3 scripts/staging_preflight.py",
    "sandbox:container:evidence": "python3 scripts/sandbox_container_evidence.py",
    "beta:validation": "python3 scripts/beta_validation_status.py",
    "qa:visual": "node scripts/visual_regression.mjs",
    "site:smoke": "node scripts/site_functionality_smoke.mjs",
    "sandbox:evidence": "apps/api/.venv/bin/python scripts/sandbox_evidence.py",
    "incident:drill": "python3 scripts/incident_response_drill.py",
    "setup:native": "bash scripts/setup_native_localhost.sh",
    "retention:dry-run": "apps/api/.venv/bin/python scripts/retention_sweep.py --dry-run",
    "retention:sweep": "apps/api/.venv/bin/python scripts/retention_sweep.py",
    "check": "npm run test && npm run test:api && npm run typecheck",
    "dev:api": "apps/api/.venv/bin/uvicorn wr3_api.main:app --app-dir apps/api --reload --reload-dir apps/api/wr3_api --host 127.0.0.1 --port 8001",
    "dev:local": "bash scripts/dev_local.sh",
    "dev:web": "npm --workspace @wr3/types run build && npm --workspace @wr3/scoring run build && npm --workspace @wr3/audit-engine run build && npm --workspace @wr3/shared run build && npm --workspace @wr3/web run dev",
    "license:inventory": "apps/api/.venv/bin/python scripts/license_inventory.py",
    "test": "npm run build:packages && npm --workspaces --if-present run test",
    "test:api": "cd apps/api && ./.venv/bin/python -m pytest",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "cloudflare:setup-storage": "bash scripts/cloudflare_storage_setup.sh"
  },
  "overrides": {
    "postcss": "8.5.10",
    "next@^15.0.0": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
